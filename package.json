{
  "name": "@mongez/copper",
  "version": "2.0.0",
  "description": "Zero-dependency CLI toolkit: ANSI colors with a 20+ palette, spinners, progress bars, boxed messages, themed loggers, OSC-8 hyperlinks, and ANSI stripping. NO_COLOR friendly.",
  "main": "src/index.ts",
  "sideEffects": false,
  "author": "hassanzohdy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hassanzohdy/copper"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "ansi",
    "colors",
    "cli",
    "terminal",
    "console",
    "chalk",
    "picocolors",
    "spinner",
    "progress-bar",
    "logger",
    "box",
    "no-color",
    "force-color",
    "osc-8",
    "hyperlink",
    "strip-ansi",
    "256-color",
    "typescript",
    "zero-dependency"
  ]
}
